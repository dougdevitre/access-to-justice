# Intake form persistence.
#
# Options:
#   file    (default) Append each submission as a JSON line to disk.
#           Rotated when the file grows past INTAKE_SINK_MAX_BYTES.
#           Intended for local development only — data is lost on
#           container restart or redeploy.
#   stdout  Emit submissions to stdout for a log collector to pick up.
#   none    Discard submissions (useful for preview environments).
#   dynamo  Write to the DynamoDB table named in INTAKE_DYNAMO_TABLE.
#           Production default. See docs/INTAKE_DYNAMODB.md for table
#           schema, IAM policy, and Vercel env var setup.

INTAKE_SINK=file

# --- file sink (only used when INTAKE_SINK=file) ---
INTAKE_SINK_DIR=.data
INTAKE_SINK_MAX_BYTES=10485760

# --- dynamo sink (only used when INTAKE_SINK=dynamo) ---
# INTAKE_DYNAMO_TABLE=a2j-intake-submissions-prod
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...

# Organization directory override.
#
# When ORGS_SOURCE_URL is set, the web app fetches the org list from
# that URL (must return a JSON array matching the schema in
# shared/ORGS.md) with Next 15 ISR caching. When unset, the app uses
# the committed seed at shared/orgs.seed.json. On any fetch / parse
# failure the app logs and falls back to the seed.
#
# ORGS_SOURCE_URL=https://a2j-prod.s3.amazonaws.com/orgs.json
# ORGS_CACHE_TTL_SECONDS=900

# Intake rate limiting (DynamoDB conditional writes).
#
# When RATE_LIMIT_TABLE is unset, rate limiting is a no-op (dev/test).
# See docs/RATE_LIMIT.md for table schema + IAM policy.
# Defaults: 5 submissions per 10 min per IP.
#
# RATE_LIMIT_TABLE=a2j-rate-limits-prod
# RATE_LIMIT_WINDOW_SECONDS=600
# RATE_LIMIT_MAX=5
# RATE_LIMIT_DISABLED=1

# Admin panel (/admin/orgs). See docs/ADMIN.md for the full setup.
# Fail-closed: without both ADMIN_PASSWORD and ADMIN_SESSION_SECRET,
# sign-in always fails.
#
# ADMIN_PASSWORD=change-me
# ADMIN_SESSION_SECRET=           # openssl rand -hex 32
# ORGS_S3_BUCKET=a2j-orgs-prod
# ORGS_S3_KEY=orgs.json
# ORGS_S3_REGION=us-east-1

# Intake confirmation email (AWS SES v2). See docs/INTAKE_EMAIL.md
# for sender-identity verification, sandbox → production, and the
# extra IAM statement on the existing AWS user.
#
# Leave INTAKE_EMAIL_SENDER=none until the AWS account is out of the
# SES sandbox; sandbox sends will 4xx for any unverified recipient.
#
# INTAKE_EMAIL_SENDER=ses
# INTAKE_EMAIL_FROM=admin@cotrackpro.com
# SES_REGION=us-east-1
# NEXT_PUBLIC_SITE_URL=https://your-domain.org

# Error monitoring (Sentry). See docs/SENTRY.md for the PII scrubber
# details and why both *_DSN vars are safe to set to the same value.
#
# SENTRY_DSN=https://....ingest.sentry.io/...
# NEXT_PUBLIC_SENTRY_DSN=https://....ingest.sentry.io/...
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=access-to-justice-web
# SENTRY_AUTH_TOKEN=              # only required for source-map upload
# SENTRY_ENVIRONMENT=production
# SENTRY_RELEASE=
