# Intake form persistence.
#
# Options:
#   file    (default) Append each submission as a JSON line to disk.
#           Rotated when the file grows past INTAKE_SINK_MAX_BYTES.
#           Intended for local development only — data is lost on
#           container restart or redeploy.
#   stdout  Emit submissions to stdout for a log collector to pick up.
#   none    Discard submissions (useful for preview environments).
#   dynamo  Write to the DynamoDB table named in INTAKE_DYNAMO_TABLE.
#           Production default. See docs/INTAKE_DYNAMODB.md for table
#           schema, IAM policy, and Vercel env var setup.

INTAKE_SINK=file

# --- file sink (only used when INTAKE_SINK=file) ---
INTAKE_SINK_DIR=.data
INTAKE_SINK_MAX_BYTES=10485760

# --- dynamo sink (only used when INTAKE_SINK=dynamo) ---
# INTAKE_DYNAMO_TABLE=a2j-intake-submissions-prod
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...

# Organization directory override.
#
# When ORGS_SOURCE_URL is set, the web app fetches the org list from
# that URL (must return a JSON array matching the schema in
# shared/ORGS.md) with Next 15 ISR caching. When unset, the app uses
# the committed seed at shared/orgs.seed.json. On any fetch / parse
# failure the app logs and falls back to the seed.
#
# ORGS_SOURCE_URL=https://a2j-prod.s3.amazonaws.com/orgs.json
# ORGS_CACHE_TTL_SECONDS=900
